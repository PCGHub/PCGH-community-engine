# Supabase project URL and anon key are safe for client-side use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role bypasses Row Level Security entirely. Per
# docs/authentication-architecture.md ("Security Principles") and
# docs/backend-architecture.md ("Security Model"), it must NEVER be
# prefixed NEXT_PUBLIC_ and must NEVER be referenced from any file that
# executes in the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# Reserved for the separate Python/FastAPI AI Service integration
# (ADR-016). Not connected to anything yet -- see app/ai/README.md.
AI_SERVICE_URL=
